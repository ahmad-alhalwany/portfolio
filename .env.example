# =============================================================================
# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables
# Never commit .env or .env.local — only this example file belongs in git.
# =============================================================================

# --- Required (production) ---
# Canonical URL — no trailing slash (SEO, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Admin panel (/admin) — use a strong password
ADMIN_PASSWORD=

# Session encryption — min 32 chars. Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IRON_SESSION_PASSWORD=

# --- Contact / hire form (EmailJS) — https://www.emailjs.com ---
NEXT_PUBLIC_SERVICE_ID=
NEXT_PUBLIC_TEMPLATE_ID=
NEXT_PUBLIC_USER_ID=

# --- Form spam protection (Cloudflare Turnstile) — https://dash.cloudflare.com ---
# Add your Vercel domain under Turnstile → Hostname Management
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_USE_PROD_KEYS=true

# --- Optional integrations ---
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
BUTTONDOWN_API_KEY=
NEXT_PUBLIC_CDN_URL=

# --- Sentry (optional) — source maps on Vercel build ---
SENTRY_AUTH_TOKEN=
# SENTRY_UPLOAD=true
