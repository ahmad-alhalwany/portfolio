# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — never commit secrets (use Vercel Environment Variables in production)
.env
.env.*
!.env.example

# runtime / local CMS data (regenerated on server)
data/subscribers.json
data/comments.json
data/rate-limits.json
data/analytics.json

# runtime uploads (regenerated on server via /api/upload — served via /api/media)
/public/uploads/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry build plugin (contains auth token)
.env.sentry-build-plugin

# local scratch
tmp-tw-out.css
